# Google Gemini — required for ai-copilot, lead-classifier, data-extractor demos
GEMINI_API_KEY=your-gemini-api-key

# Green API (WhatsApp gateway) — only needed if wiring the whatsapp-agent to a real instance
GREEN_API_INSTANCE_ID=your-instance-id
GREEN_API_TOKEN=your-api-token

# Call-recording pipeline (Maskyoo example) — shared secret between the relay and the ingest endpoint
INGEST_SHARED_SECRET=generate-a-long-random-string
